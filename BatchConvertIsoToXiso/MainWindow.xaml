<Window x:Class="BatchConvertIsoToXiso.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:BatchConvertIsoToXiso.Services"
        Title="Batch Convert ISO to XISO"
        Height="850" Width="1200" MinHeight="650" MinWidth="700"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Converter for the XIso Explorer icons -->
        <services:FolderIconConverter x:Key="FolderIconConverter" />
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 0: Header -->
            <RowDefinition Height="*" />    <!-- 1: Main Content -->
            <RowDefinition Height="Auto" /> <!-- 2: StatusBar -->
        </Grid.RowDefinitions>

        <!-- Header (RomValidator Style) -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Batch ISO to XISO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeaderTextBrush}" VerticalAlignment="Center" Margin="0,0,30,0" />
                    <Button x:Name="BtnNavConvert" Content="Convert" Click="NavConvert_Click" Style="{StaticResource MenuButtonStyle}" />
                    <Button x:Name="BtnNavTest" Content="Test Integrity" Click="NavTest_Click" Style="{StaticResource MenuButtonStyle}" />
                    <Button x:Name="BtnNavExplorer" Content="Explorer" Click="NavExplorer_Click" Style="{StaticResource MenuButtonStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="About" Click="AboutMenuItem_Click" Style="{StaticResource MenuButtonStyle}" Background="{StaticResource AboutButtonBrush}" ToolTip="View application information" />
                    <Button Content="Exit" Click="ExitMenuItem_Click" Style="{StaticResource MenuButtonStyle}" Background="{StaticResource ExitButtonBrush}" ToolTip="Close the application" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- 0: Operation Controls -->
                <RowDefinition Height="*" />    <!-- 1: Log/Explorer -->
                <RowDefinition Height="Auto" /> <!-- 2: Stats -->
                <RowDefinition Height="Auto" /> <!-- 3: Progress -->
            </Grid.RowDefinitions>

            <!-- 0. Operation Controls (Styled like RomValidator Borders) -->
            <Border x:Name="ControlsBorder" Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <!-- Conversion View -->
                    <StackPanel x:Name="ConvertView">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Content="Source Folder:" />
                            <TextBox x:Name="ConversionInputFolderTextBox" Grid.Column="1" Style="{StaticResource CustomTextBoxStyle}" IsReadOnly="True" Margin="5,0" ToolTip="Select the folder containing ISO or archive files" />
                            <Button Grid.Column="2" Content="Browse..." Click="BrowseConversionInputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse for source folder" />
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Content="Output Folder:" />
                            <TextBox x:Name="ConversionOutputFolderTextBox" Grid.Column="1" Style="{StaticResource CustomTextBoxStyle}" IsReadOnly="True" Margin="5,0" ToolTip="Select the output folder for converted XISO files" />
                            <Button Grid.Column="2" Content="Browse..." Click="BrowseConversionOutputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse for output folder" />
                        </Grid>
                        <Grid Margin="0,5,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <GroupBox Grid.Column="0" Header="Options" Margin="0,5,15,5" Padding="10,5" Style="{StaticResource CustomGroupBoxStyle}">
                                <StackPanel Orientation="Vertical">
                                    <CheckBox x:Name="DeleteOriginalsCheckBox" Content="Delete original files after successful conversion" Margin="0,2,0,2" HorizontalAlignment="Left" ToolTip="Deletes the original ISO/archive if conversion is successful. Use with caution!" Style="{StaticResource CustomCheckBoxStyle}" />
                                    <CheckBox x:Name="SearchSubfoldersConversionCheckBox" Content="Search for files in subfolders" Margin="0,8,0,8" HorizontalAlignment="Left" ToolTip="Include files found in subdirectories of the source folder" Style="{StaticResource CustomCheckBoxStyle}" />
                                    <CheckBox x:Name="SkipSystemUpdateCheckBox" Content="Skip $SystemUpdate folder during conversion" Margin="0,2,0,2" HorizontalAlignment="Left" ToolTip="Omits the $SystemUpdate folder from the output XISO, reducing file size" Style="{StaticResource CustomCheckBoxStyle}" />
                                    <CheckBox x:Name="CheckOutputIntegrityCheckBox" Content="Check integrity of the output file" Margin="0,8,0,8" HorizontalAlignment="Left" IsChecked="True" ToolTip="Performs a structural integrity check on the newly created XISO file" Style="{StaticResource CustomCheckBoxStyle}" />
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Grid.Column="1" Header="Conversion Method" Margin="0,5,0,5" Padding="10,5" VerticalAlignment="Top" Style="{StaticResource CustomGroupBoxStyle}">
                                <StackPanel Orientation="Vertical">
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <RadioButton x:Name="UseExtractXisoRadioButton" GroupName="ConversionMethod" Content="Use extract-xiso.exe tool" ToolTip="Uses the external extract-xiso.exe tool for conversion (default)" VerticalAlignment="Center" />
                                        <TextBlock Text=" (https://github.com/XboxDev/extract-xiso)" Foreground="{StaticResource LinkTextBrush}" Cursor="Hand" MouseLeftButtonDown="ExtractXisoUrl_Click" TextDecorations="Underline" Margin="5,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <RadioButton x:Name="UseXdvdfsRadioButton" GroupName="ConversionMethod" Content="Use xdvdfs.exe tool" ToolTip="Uses the external xdvdfs.exe tool for conversion" IsChecked="True" VerticalAlignment="Center" />
                                        <TextBlock Text=" (https://github.com/antangelo/xdvdfs)" Foreground="{StaticResource LinkTextBrush}" Cursor="Hand" MouseLeftButtonDown="XdvdfsUrl_Click" TextDecorations="Underline" Margin="5,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <RadioButton x:Name="UseBuiltInLogicRadioButton" GroupName="ConversionMethod" Content="Use enhanced Deterous logic (built-in)" ToolTip="Uses the application's built-in XISO conversion logic" VerticalAlignment="Center" />
                                        <TextBlock Text=" (https://github.com/Deterous/XboxKit)" Foreground="{StaticResource LinkTextBrush}" Cursor="Hand" MouseLeftButtonDown="DeterousUrl_Click" TextDecorations="Underline" Margin="5,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </Grid>
                        <Button x:Name="StartConversionButton" Content="Start Conversion" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Center" Margin="0,5,0,0" Click="StartConversionButton_Click" ToolTip="Begin the batch conversion process" />
                    </StackPanel>

                    <!-- Test View (Hidden by default) -->
                    <StackPanel x:Name="TestView" Visibility="Collapsed">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Content="ISO Folder:" />
                            <TextBox x:Name="TestInputFolderTextBox" Grid.Column="1" Style="{StaticResource CustomTextBoxStyle}" IsReadOnly="True" Margin="5,0" ToolTip="Select the folder containing ISO files to test" />
                            <Button Grid.Column="2" Content="Browse..." Click="BrowseTestInputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse for ISO folder" />
                        </Grid>
                        <GroupBox Header="Options" Margin="0,5,0,5" Padding="10,5" Style="{StaticResource CustomGroupBoxStyle}">
                            <StackPanel Orientation="Vertical">
                                <CheckBox x:Name="MoveSuccessFilesCheckBox" Content="Move successfully tested ISOs to a '_success' subfolder" Margin="0,5,0,0" HorizontalAlignment="Left" IsChecked="False" ToolTip="Moves valid ISOs to a '_success' folder within the source folder" Style="{StaticResource CustomCheckBoxStyle}" />
                                <CheckBox x:Name="MoveFailedFilesCheckBox" Content="Move failed tested ISOs to a '_failed' subfolder" Margin="0,5,0,0" HorizontalAlignment="Left" IsChecked="False" ToolTip="Moves invalid ISOs to a '_failed' folder within the source folder" Style="{StaticResource CustomCheckBoxStyle}" />
                                <CheckBox x:Name="PerformDeepScanCheckBox" Content="Perform deep surface scan (slower)" Margin="0,5,0,5" HorizontalAlignment="Left" IsChecked="False" ToolTip="Reads entire ISO sequentially to detect bad sectors. Unchecked performs logical file test only (faster)." Style="{StaticResource CustomCheckBoxStyle}" />
                            </StackPanel>
                        </GroupBox>
                        <Button x:Name="StartTestButton" Content="Start Integrity Test" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Center" Margin="0,5,0,0" Click="StartTestButton_Click" ToolTip="Begin the batch integrity test process" />
                    </StackPanel>

                    <!-- Explorer View Header -->
                    <StackPanel x:Name="ExplorerHeaderView" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Label Content="Select XISO File:" />
                            <TextBox x:Name="ExplorerFilePathTextBox" Grid.Column="1" Style="{StaticResource CustomTextBoxStyle}" IsReadOnly="True" Margin="5,0" ToolTip="Select an Xbox ISO file to explore its contents" />
                            <Button Content="Browse..." Grid.Column="2" Click="BrowseExplorerFile_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse for an XISO file" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 1. Log / Explorer Content -->
            <Grid Grid.Row="1">
                <Border x:Name="LogBorder" BorderBrush="{StaticResource TerminalBorderBrush}" BorderThickness="2" CornerRadius="4" Background="{StaticResource TerminalBackgroundBrush}">
                     <TextBox x:Name="LogViewer"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="13"
                             Background="{StaticResource TerminalBackgroundBrush}"
                             Foreground="{StaticResource TerminalForegroundBrush}"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="8"
                             CaretBrush="{StaticResource TerminalForegroundBrush}">
                        <TextBox.Effect>
                            <DropShadowEffect ShadowDepth="0" Color="#39FF14" BlurRadius="2" Opacity="0.4"/>
                        </TextBox.Effect>
                    </TextBox>
                </Border>

                <Border x:Name="ExplorerBorder" Visibility="Collapsed" BorderBrush="{StaticResource TerminalBorderBrush}" BorderThickness="2" CornerRadius="4" Background="{StaticResource TerminalBackgroundBrush}" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" /> <!-- Navigation Bar -->
                            <RowDefinition Height="*" />    <!-- File List -->
                        </Grid.RowDefinitions>

                        <!-- Navigation Bar -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                            <Button x:Name="ExplorerUpButton" Content="⬆ Up" Click="ExplorerUpButton_Click" Width="60" Margin="0,0,10,0" IsEnabled="False" Style="{StaticResource ActionButtonStyle}" ToolTip="Go up one directory level" />
                            <TextBlock Text="Current Path: " VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TerminalForegroundBrush}" />
                            <TextBlock x:Name="ExplorerPathTextBlock" Text="/" VerticalAlignment="Center" Foreground="{StaticResource TerminalForegroundBrush}" />
                        </StackPanel>

                        <!-- File List -->
                        <ListView x:Name="ExplorerListView" Grid.Row="1" MouseDoubleClick="ExplorerListView_MouseDoubleClick" PreviewMouseLeftButtonDown="ExplorerListView_PreviewMouseLeftButtonDown" MouseMove="ExplorerListView_MouseMove" BorderThickness="0" Background="{StaticResource TerminalBackgroundBrush}" ItemContainerStyle="{StaticResource ExplorerListViewItemStyle}">
                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource ExplorerGridViewColumnHeaderStyle}">
                                    <GridViewColumn Width="450">
                                        <GridViewColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="Name" Foreground="{StaticResource TerminalForegroundBrush}" FontWeight="Bold" HorizontalAlignment="Left" Padding="10,5" />
                                            </DataTemplate>
                                        </GridViewColumn.HeaderTemplate>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding IsDirectory, Converter={StaticResource FolderIconConverter}}" Margin="0,0,5,0" Foreground="{StaticResource TerminalForegroundBrush}" />
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TerminalForegroundBrush}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="120">
                                        <GridViewColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="Size" Foreground="{StaticResource TerminalForegroundBrush}" FontWeight="Bold" HorizontalAlignment="Left" Padding="10,5" />
                                            </DataTemplate>
                                        </GridViewColumn.HeaderTemplate>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SizeFormatted}" Foreground="{StaticResource TerminalForegroundBrush}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="100">
                                        <GridViewColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="Type" Foreground="{StaticResource TerminalForegroundBrush}" FontWeight="Bold" HorizontalAlignment="Left" Padding="10,5" />
                                            </DataTemplate>
                                        </GridViewColumn.HeaderTemplate>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Type}" Foreground="{StaticResource TerminalForegroundBrush}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- 2. Stats Panel -->
            <Grid x:Name="StatsPanel" Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource StatsCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Total Files:" Style="{StaticResource StatsLabelStyle}"/>
                        <TextBlock x:Name="TotalFilesValue" Text="0" Style="{StaticResource StatsValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource StatsCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Success:" Style="{StaticResource StatsLabelStyle}" Foreground="{StaticResource SuccessTextBrush}"/>
                        <TextBlock x:Name="SuccessValue" Text="0" Style="{StaticResource StatsValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource StatsCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Failed:" Style="{StaticResource StatsLabelStyle}" Foreground="{StaticResource FailedTextBrush}"/>
                        <TextBlock x:Name="FailedValue" Text="0" Style="{StaticResource StatsValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource StatsCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Skipped:" Style="{StaticResource StatsLabelStyle}" Foreground="{StaticResource SkippedTextBrush}"/>
                        <TextBlock x:Name="SkippedValue" Text="0" Style="{StaticResource StatsValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource StatsCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Time:" Style="{StaticResource StatsLabelStyle}"/>
                        <TextBlock x:Name="ProcessingTimeValue" Text="00:00:00" Style="{StaticResource StatsValueStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="5" Style="{StaticResource StatsCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Read Speed:" Style="{StaticResource StatsLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="ReadSpeedValue" Text="N/A" Style="{StaticResource StatsValueStyle}"/>
                            <TextBlock x:Name="ReadSpeedDriveIndicator" Text="" Margin="5,0,0,0" Style="{StaticResource StatsValueStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="6" Style="{StaticResource StatsCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Write Speed:" Style="{StaticResource StatsLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="WriteSpeedValue" Text="N/A" Style="{StaticResource StatsValueStyle}"/>
                            <TextBlock x:Name="WriteSpeedDriveIndicator" Text="" Margin="5,0,0,0" Style="{StaticResource StatsValueStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 3. Progress Area -->
            <Grid x:Name="ProgressAreaGrid" Grid.Row="3" Margin="0,10,0,0" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="1" Background="{StaticResource CardBackgroundBrush}">
                    <Grid>
                        <ProgressBar x:Name="ProgressBar" Height="24" Foreground="{StaticResource ProgressForegroundBrush}" Background="{StaticResource ProgressBackgroundBrush}" BorderThickness="0" />
                        <TextBlock x:Name="ProgressTextBlock" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                    </Grid>
                </Border>
                <Button x:Name="CancelButton" Grid.Column="1" Content="Cancel" Style="{StaticResource CancelButtonStyle}" Margin="10,0,0,0" Visibility="Collapsed" Click="CancelButton_Click" ToolTip="Cancel the current operation" />
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource StatusBarBackgroundBrush}" Padding="5">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusTextBlock" Text="Ready." />
            </StatusBarItem>

            <StatusBarItem Grid.Column="1">
                <TextBlock x:Name="MemoryTextBlock" Text="Memory: 0 MB" FontSize="11" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>